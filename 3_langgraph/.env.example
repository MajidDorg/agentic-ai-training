# Copy this file to ".env" (exactly that) and paste your real keys after each = sign.
# The .env file is gitignored, so your keys never get committed or pushed.

# Required — your OpenAI key (starts with sk-proj-): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Required for Lab 2's web-search tool — free key, no card: https://serper.dev
SERPER_API_KEY=

# Lab 2's notification tool — sends a push to your phone via Pushover (https://pushover.net).
# PUSHOVER_USER = "Your User Key" on the pushover.net dashboard.
# PUSHOVER_TOKEN = the API Token of an Application you create on pushover.net.
# (Install the Pushover phone app and log in to actually receive the push.)
PUSHOVER_USER=
PUSHOVER_TOKEN=

# Optional — LangSmith tracing (Lab 2). Free: https://smith.langchain.com (Settings -> API Keys)
# LANGCHAIN_API_KEY=
# LANGCHAIN_TRACING_V2=true
